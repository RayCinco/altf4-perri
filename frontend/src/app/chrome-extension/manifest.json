{
  "manifest_version": 3,
  "name": "Perri",
  "version": "1.3",
  "description": "Analyze text, URLs, and images for chismis level.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Perri",
    "default_icon": {
      "16": "icons/perri.png",
      "32": "icons/perri.png",
      "48": "icons/perri.png",
      "128": "icons/perri.png"
    }
  },
  "permissions": ["activeTab", "storage"]
}