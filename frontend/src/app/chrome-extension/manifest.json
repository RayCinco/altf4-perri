{
  "manifest_version": 3,
  "name": "Perri",
  "version": "1.0",
  "description": "Detect chismis in text, URLs, images, and screenshots.",

  "permissions": ["activeTab", "tabs"],

  "host_permissions": ["http://localhost:3000/*", "https://*.vercel.app/*"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/perri.png",
      "32": "icons/perri.png",
      "48": "icons/perri.png",
      "128": "icons/perri.png"
    }
  }
}
